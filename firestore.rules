rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, role (admin/student), createdAt
    //
    // Collection: courses
    // Fields: title, description, price, category, imageUrl, active
    //
    // Collection: notices
    // Fields: title, content, date, active
    //
    // Collection: routines
    // Fields: day, time, subject, teacher
    //
    // Collection: fees
    // Fields: userId, studentName, amount, status (paid/unpaid), date, receiptId
    //
    // Collection: classes
    // Fields: title, description, videoLink, date
    //
    // Collection: admissions
    // Fields: studentName, fatherName, motherName, schoolName, studentClass, district, userId, status, createdAt
    //
    // Collection: settings
    // Fields: text, link
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "mdrifat.contact@gmail.com")
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.email is string &&
             data.role in ['admin', 'student'];
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['title', 'shortDescription', 'detailedDescription', 'price', 'category']) &&
             data.title is string && data.title.size() < 200 &&
             data.shortDescription is string && data.shortDescription.size() < 1000 &&
             data.detailedDescription is string && data.detailedDescription.size() < 10000 &&
             data.price is number && data.price >= 0 &&
             (!('features' in data) || data.features is list) &&
             (!('speciality' in data) || data.speciality is string);
    }

    function isValidNotice(data) {
      return data.keys().hasAll(['title', 'content', 'date']) &&
             data.title is string && data.title.size() < 500 &&
             data.content is string && data.content.size() < 10000;
    }

    function isValidRoutine(data) {
      let days = ['Saturday', 'Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday',
                  'শনিবার', 'রবিবার', 'সোমবার', 'মঙ্গলবার', 'বুধবার', 'বৃহস্পতিবার', 'শুক্রবার'];
      return data.keys().hasAll(['day', 'time', 'subject']) &&
             data.day in days;
    }

    function isValidFee(data) {
      return data.keys().hasAll(['userId', 'amount', 'status']) &&
             data.userId is string && data.amount is number &&
             data.status in ['paid', 'unpaid'];
    }

    function isValidClass(data) {
      return data.keys().hasAll(['title', 'videoLink', 'date']) &&
             data.title is string && data.videoLink is string;
    }

    function isValidAdmission(data) {
      return data.keys().hasAll(['studentName', 'fatherName', 'motherName', 'schoolName', 'studentClass', 'district', 'userId', 'courseId']) &&
             data.studentName is string && data.studentName.size() < 100 &&
             data.userId is string && data.courseId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) && request.resource.data.role == 'student' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin());
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCourse(request.resource.data);
    }

    match /notices/{noticeId} {
      allow read: if true;
      allow write: if isAdmin() && isValidNotice(request.resource.data);
    }

    match /routines/{routineId} {
      allow read: if true;
      allow write: if isAdmin() && isValidRoutine(request.resource.data);
    }

    match /fees/{feeId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if isAdmin() && isValidFee(request.resource.data);
    }

    match /classes/{classId} {
      allow read: if true;
      allow write: if isAdmin() && isValidClass(request.resource.data);
    }

    match /admissions/{admissionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidAdmission(request.resource.data) && isOwner(request.resource.data.userId) && request.resource.data.status == 'pending';
      allow update: if isAdmin() && isValidAdmission(request.resource.data);
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
