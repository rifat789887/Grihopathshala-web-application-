rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: notices
    // Fields: title (string), date (string), content (string), active (bool), category (string)
    //
    // Collection: routines
    // Fields: day (string), subject (string), teacher (string), time (string)
    //
    // Collection: classes
    // Fields: title (string), date (string), link (string), teacher (string)
    //
    // Collection: courses
    // Fields: title (string), description (string), shortDescription (string), price (number), active (bool), category (string), imageUrl (string)
    //
    // Collection: settings
    // Document: marquee
    // Fields: text (string), link (string)
    //
    // Collection: users
    // Fields: uid (string), email (string), role (string), displayName (string), photoURL (string)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "mdrifat.contact@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'student'];
    }

    function isValidNotice(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.date is string &&
             data.content is string &&
             data.active is bool;
    }

    function isValidRoutine(data) {
      return data.day is string &&
             data.subject is string &&
             data.teacher is string &&
             data.time is string;
    }

    function isValidClass(data) {
      return data.title is string &&
             data.date is string &&
             data.link is string &&
             data.teacher is string;
    }

    function isValidCourse(data) {
      return data.title is string &&
             data.price is number &&
             data.active is bool &&
             data.category is string;
    }

    function isValidMarquee(data) {
      return data.text is string &&
             data.link is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'student' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /notices/{noticeId} {
      allow read: if true;
      allow write: if isAdmin() && isValidNotice(request.resource.data);
    }

    match /routines/{routineId} {
      allow read: if true;
      allow write: if isAdmin() && isValidRoutine(request.resource.data);
    }

    match /classes/{classId} {
      allow read: if true;
      allow write: if isAdmin() && isValidClass(request.resource.data);
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCourse(request.resource.data);
    }

    match /settings/marquee {
      allow read: if true;
      allow write: if isAdmin() && isValidMarquee(request.resource.data);
    }
  }
}
