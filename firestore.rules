rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: notices
    // Fields: title (string), date (string), content (string), active (bool), category (string)
    //
    // Collection: routines
    // Fields: day (string), subject (string), teacher (string), time (string)
    //
    // Collection: classes
    // Fields: title (string), date (string), link (string), teacher (string)
    //
    // Collection: courses
    // Fields: title (string), description (string), shortDescription (string), price (number), active (bool), category (string), imageUrl (string)
    //
    // Collection: settings
    // Document: marquee
    // Fields: text (string), link (string)
    //
    // Collection: users
    // Fields: uid (string), email (string), role (string), displayName (string), photoURL (string)
    //
    // Collection: admissions
    // Fields: studentName (string), fatherName (string), schoolName (string), district (string), course (string), class (string), mobileNumber (string), whatsappNumber (string), status (string), paymentStatus (string), userId (string), userEmail (string), createdAt (string)
    //
    // Collection: fees
    // Fields: userId (string), studentName (string), amount (number), status (string), date (string), receiptId (string)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email == "mdrifat.contact@gmail.com" && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'student'];
    }

    function isValidNotice(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.date is string &&
             data.content is string &&
             data.active is bool;
    }

    function isValidRoutine(data) {
      return data.day is string &&
             data.subject is string &&
             data.teacher is string &&
             data.time is string;
    }

    function isValidClass(data) {
      return data.title is string &&
             data.date is string &&
             data.link is string &&
             data.teacher is string;
    }

    function isValidCourse(data) {
      return data.title is string &&
             data.price is number &&
             data.active is bool &&
             data.category is string;
    }

    function isValidMarquee(data) {
      return data.text is string &&
             data.link is string;
    }

    function isValidAdmission(data) {
      return data.studentName is string && data.studentName.size() > 0 && data.studentName.size() < 100 &&
             data.course is string &&
             data.class is string &&
             data.mobileNumber is string && data.mobileNumber.size() >= 10 && data.mobileNumber.size() <= 15 &&
             data.whatsappNumber is string && data.whatsappNumber.size() >= 10 && data.whatsappNumber.size() <= 15 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.paymentStatus in ['paid', 'unpaid'] &&
             data.userId is string &&
             data.userEmail is string &&
             data.createdAt is string;
    }

    function isValidFee(data) {
      return data.userId is string &&
             data.studentName is string &&
             data.amount is number &&
             data.status in ['paid', 'unpaid'] &&
             data.date is string &&
             data.receiptId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'student' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /notices/{noticeId} {
      allow read: if true;
      allow write: if isAdmin() && isValidNotice(request.resource.data);
    }

    match /routines/{routineId} {
      allow read: if true;
      allow write: if isAdmin() && isValidRoutine(request.resource.data);
    }

    match /classes/{classId} {
      allow read: if true;
      allow write: if isAdmin() && isValidClass(request.resource.data);
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCourse(request.resource.data);
    }

    match /settings/marquee {
      allow read: if true;
      allow write: if isAdmin() && isValidMarquee(request.resource.data);
    }

    match /admissions/{admissionId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidAdmission(request.resource.data) && request.resource.data.userId == request.auth.uid && request.resource.data.status == 'pending' && request.resource.data.paymentStatus == 'unpaid';
      allow update: if isAdmin() && isValidAdmission(request.resource.data);
      allow delete: if isAdmin();
    }

    match /fees/{feeId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin() && isValidFee(request.resource.data);
    }
  }
}
