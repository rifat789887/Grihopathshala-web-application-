{
  "entities": {
    "Notice": {
      "title": "Notice",
      "description": "A notice or blog post",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "content": { "type": "string" },
        "active": { "type": "boolean" },
        "category": { "type": "string" }
      },
      "required": ["title", "date", "content", "active"]
    },
    "Routine": {
      "title": "Routine",
      "description": "A class routine entry",
      "type": "object",
      "properties": {
        "day": { "type": "string" },
        "subject": { "type": "string" },
        "teacher": { "type": "string" },
        "time": { "type": "string" }
      },
      "required": ["day", "subject", "teacher", "time"]
    },
    "Class": {
      "title": "Class",
      "description": "A live or recorded class",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "link": { "type": "string" },
        "teacher": { "type": "string" }
      },
      "required": ["title", "date", "link", "teacher"]
    },
    "Course": {
      "title": "Course",
      "description": "An educational course",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "shortDescription": { "type": "string" },
        "price": { "type": "number" },
        "active": { "type": "boolean" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["title", "price", "active", "category"]
    },
    "Marquee": {
      "title": "Marquee",
      "description": "Marquee settings",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "link": { "type": "string" }
      },
      "required": ["text", "link"]
    },
    "User": {
      "title": "User",
      "description": "A user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/notices/{noticeId}": {
      "schema": "Notice",
      "description": "Collection of notices and blog posts"
    },
    "/routines/{routineId}": {
      "schema": "Routine",
      "description": "Collection of class routines"
    },
    "/classes/{classId}": {
      "schema": "Class",
      "description": "Collection of classes"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Collection of courses"
    },
    "/settings/marquee": {
      "schema": "Marquee",
      "description": "Marquee settings document"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
