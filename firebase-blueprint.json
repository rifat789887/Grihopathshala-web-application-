{
  "entities": {
    "Notice": {
      "title": "Notice",
      "description": "A notice or blog post",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "content": { "type": "string" },
        "active": { "type": "boolean" },
        "category": { "type": "string" }
      },
      "required": ["title", "date", "content", "active"]
    },
    "Routine": {
      "title": "Routine",
      "description": "A class routine entry",
      "type": "object",
      "properties": {
        "day": { "type": "string" },
        "subject": { "type": "string" },
        "teacher": { "type": "string" },
        "time": { "type": "string" }
      },
      "required": ["day", "subject", "teacher", "time"]
    },
    "Class": {
      "title": "Class",
      "description": "A live or recorded class",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "link": { "type": "string" },
        "teacher": { "type": "string" }
      },
      "required": ["title", "date", "link", "teacher"]
    },
    "Course": {
      "title": "Course",
      "description": "An educational course",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "shortDescription": { "type": "string" },
        "price": { "type": "number" },
        "active": { "type": "boolean" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["title", "price", "active", "category"]
    },
    "Marquee": {
      "title": "Marquee",
      "description": "Marquee settings",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "link": { "type": "string" }
      },
      "required": ["text", "link"]
    },
    "User": {
      "title": "User",
      "description": "A user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Admission": {
      "title": "Admission",
      "description": "A student admission application",
      "type": "object",
      "properties": {
        "studentName": { "type": "string" },
        "fatherName": { "type": "string" },
        "schoolName": { "type": "string" },
        "district": { "type": "string" },
        "course": { "type": "string" },
        "class": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "paymentStatus": { "type": "string", "enum": ["paid", "unpaid"] },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentName", "course", "class", "mobileNumber", "whatsappNumber", "status", "paymentStatus", "userId", "userEmail", "createdAt"]
    },
    "Fee": {
      "title": "Fee",
      "description": "A fee payment record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "studentName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "unpaid"] },
        "date": { "type": "string", "format": "date-time" },
        "receiptId": { "type": "string" }
      },
      "required": ["userId", "studentName", "amount", "status", "date", "receiptId"]
    }
  },
  "firestore": {
    "/notices/{noticeId}": {
      "schema": "Notice",
      "description": "Collection of notices and blog posts"
    },
    "/routines/{routineId}": {
      "schema": "Routine",
      "description": "Collection of class routines"
    },
    "/classes/{classId}": {
      "schema": "Class",
      "description": "Collection of classes"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Collection of courses"
    },
    "/settings/marquee": {
      "schema": "Marquee",
      "description": "Marquee settings document"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/admissions/{admissionId}": {
      "schema": "Admission",
      "description": "Student admission applications"
    },
    "/fees/{feeId}": {
      "schema": "Fee",
      "description": "Fee payment records"
    }
  }
}
